<section class="forja-skills tab" data-group="primary" data-tab="skills">
  {{#if hasSkills}}
    <ul class="forja-skill-list">
      {{#each skills}}
        <li class="forja-skill-row" data-item-id="{{this.id}}">
          <span class="forja-skill-row__name">{{this.name}}</span>
          <input type="number" name="items.{{this.id}}.system.level" value="{{this.system.level}}"
                 class="forja-skill-row__level-input" min="0" max="{{this.system.maxLevel}}" />
          <button type="button" class="forja-skill-row__roll" data-action="rollSkill"
                  title="{{localize 'FORJA.Roll'}} {{this.name}}">
            <i class="fas fa-dice-d10"></i>
          </button>
          <div class="forja-item-controls">
            <a class="forja-item-control" data-action="itemEdit" data-item-id="{{this.id}}"
               title="{{localize 'FORJA.ItemEdit'}}">
              <i class="fas fa-edit"></i>
            </a>
            <a class="forja-item-control" data-action="itemDelete" data-item-id="{{this.id}}"
               title="{{localize 'FORJA.ItemDelete'}}">
              <i class="fas fa-trash"></i>
            </a>
          </div>
        </li>
      {{/each}}
    </ul>
  {{else}}
    <div class="forja-empty-state">
      <i class="fas fa-book forja-empty-state__icon"></i>
      <p class="forja-empty-state__text">{{localize "FORJA.EmptySkills"}}</p>
    </div>
  {{/if}}
</section>
