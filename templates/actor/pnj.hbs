<div class="forja-pnj-sheet">
  <!-- Header -->
  <header class="pnj-header">
    <img class="actor-portrait-sm" src="{{actor.img}}" alt="{{actor.name}}" data-action="editImage" data-edit="img"/>
    <div class="pnj-header-info">
      <input class="actor-name" type="text" name="name" value="{{actor.name}}"/>
      <div class="pnj-tier">
        <label>{{localize "FORJA.PNJ.TierLabel"}}</label>
        <select name="system.tier">
          {{#each tiers as |t|}}
          <option value="{{t}}" {{#if (eq t ../sys.tier)}}selected{{/if}}>
            {{localize (concat "FORJA.TierOpcio." t)}}
          </option>
          {{/each}}
        </select>
      </div>
    </div>
  </header>

  <!-- Atributs + Derivats -->
  <div class="pnj-body">
    <div class="forja-section">
      <div class="atributs-grid-sm">
        {{#each campos.atributs as |attr|}}
        <div class="atribut-box-sm">
          <label>{{attr}}</label>
          <input type="number" name="system.atributs.{{attr}}" value="{{lookup ../sys.atributs attr}}"
                 min="0" max="5" class="atribut-input"/>
        </div>
        {{/each}}
      </div>
      <div class="pnj-secundaris">
        <span>{{localize "FORJA.Attr.Mida"}}</span>
        <input type="number" name="system.mida" value="{{sys.mida}}" min="1" max="5" class="secundari-input-sm"/>
        <span>{{localize "FORJA.Attr.Constitucio"}}</span>
        <input type="number" name="system.constitucio" value="{{sys.constitucio}}" min="1" max="5" class="secundari-input-sm"/>
      </div>
      <div class="derivats-grid-sm">
        <div class="derivat-box-sm">
          <label>{{localize "FORJA.Derivat.Latencia"}}</label>
          <span>{{derivats.latenciaBase}}</span>
        </div>
        <div class="derivat-box-sm">
          <label>{{localize "FORJA.Derivat.Defensa"}}</label>
          <span>{{derivats.defensa}}</span>
        </div>
        <div class="derivat-box-sm">
          <label>{{localize "FORJA.Derivat.Reduccio"}}</label>
          <span>{{derivats.reduccioDany}}</span>
        </div>
      </div>
    </div>

    <!-- Salut compacta -->
    <div class="forja-section">
      <h4>{{localize "FORJA.Section.Salut"}}</h4>
      <div class="salut-pistes-sm">
        {{#each salutFerides.nivells as |n|}}
        <div class="pista-nivell-sm {{#if (eq n.num 7)}}nivell-terminal{{/if}}">
          {{#each n.caselles as |c|}}
          <button type="button" class="casella-salut-sm {{#if c.marcat}}marcada{{/if}}"
                  data-action="toggleSalut" data-track="ferides" data-idx="{{c.idx}}"></button>
          {{/each}}
        </div>
        {{/each}}
      </div>
      <div class="pista-fatiga-label">{{localize "FORJA.Salut.Fatiga"}}</div>
      <div class="salut-pistes-sm">
        {{#each salutFatiga.nivells as |n|}}
        <div class="pista-nivell-sm {{#if (eq n.num 7)}}nivell-terminal{{/if}}">
          {{#each n.caselles as |c|}}
          <button type="button" class="casella-salut-sm {{#if c.marcat}}marcada{{/if}}"
                  data-action="toggleSalut" data-track="fatiga" data-idx="{{c.idx}}"></button>
          {{/each}}
        </div>
        {{/each}}
      </div>
      {{#if penalitzacio}}
        <p class="penalitzacio-badge">−{{penalitzacio}} {{localize "FORJA.Salut.Penalitzacio"}}</p>
      {{/if}}
    </div>
  </div>
</div>
