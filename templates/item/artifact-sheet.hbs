<form class="forja-item-sheet forja-artifact-sheet" autocomplete="off">
  <header class="forja-item-sheet__header">
    <img src="{{document.img}}" alt="{{document.name}}" class="forja-item-sheet__img" data-edit="img" />
    <div class="forja-item-sheet__title">
      <input type="text" name="name" value="{{document.name}}" class="forja-item-sheet__name"
             placeholder="{{localize 'FORJA.ArtifactName'}}" />
    </div>
  </header>

  <div class="forja-item-sheet__body">
    {{!-- Cost --}}
    <div class="forja-form-group">
      <label>{{localize "FORJA.Cost"}}</label>
      <input type="number" name="system.cost" value="{{system.cost}}" />
    </div>

    {{!-- Activation type --}}
    <div class="forja-form-group">
      <label>{{localize "FORJA.Activation.label"}}</label>
      <select name="system.activation">
        {{#each cfg.activationTypes as |label key|}}
          <option value="{{key}}" {{#if (eq key ../system.activation)}}selected{{/if}}>
            {{localize label}}
          </option>
        {{/each}}
      </select>
    </div>

    {{!-- Difficulty --}}
    <div class="forja-form-group">
      <label>{{localize "FORJA.Difficulty"}}</label>
      <input type="number" name="system.difficulty" value="{{system.difficulty}}" min="0" />
    </div>

    {{!-- Latency mod --}}
    <div class="forja-form-group">
      <label>{{localize "FORJA.LatencyMod"}}</label>
      <input type="number" name="system.latencyMod" value="{{system.latencyMod}}" />
    </div>

    {{!-- Range --}}
    <div class="forja-form-group">
      <label>{{localize "FORJA.Range.label"}}</label>
      <select name="system.range">
        <option value="">--</option>
        {{#each cfg.rangeTypes as |label key|}}
          <option value="{{key}}" {{#if (eq key ../system.range)}}selected{{/if}}>
            {{localize label}}
          </option>
        {{/each}}
      </select>
    </div>

    {{!-- Target --}}
    <div class="forja-form-group">
      <label>{{localize "FORJA.Target.label"}}</label>
      <select name="system.target">
        <option value="">--</option>
        {{#each cfg.targetTypes as |label key|}}
          <option value="{{key}}" {{#if (eq key ../system.target)}}selected{{/if}}>
            {{localize label}}
          </option>
        {{/each}}
      </select>
    </div>

    {{!-- Duration --}}
    <div class="forja-form-group">
      <label>{{localize "FORJA.Duration.label"}}</label>
      <select name="system.duration">
        <option value="">--</option>
        {{#each cfg.durationTypes as |label key|}}
          <option value="{{key}}" {{#if (eq key ../system.duration)}}selected{{/if}}>
            {{localize label}}
          </option>
        {{/each}}
      </select>
    </div>

    {{!-- Charges --}}
    <div class="forja-form-row">
      <div class="forja-form-group forja-form-group--half">
        <label>{{localize "FORJA.Charges"}} ({{localize "FORJA.Current"}})</label>
        <input type="number" name="system.charges.value" value="{{system.charges.value}}" min="0" />
      </div>
      <div class="forja-form-group forja-form-group--half">
        <label>{{localize "FORJA.Charges"}} ({{localize "FORJA.Max"}})</label>
        <input type="number" name="system.charges.max" value="{{system.charges.max}}" min="0" />
      </div>
    </div>

    {{!-- Recharge rate --}}
    <div class="forja-form-group">
      <label>{{localize "FORJA.RechargeRate"}}</label>
      <input type="number" name="system.rechargeRate" value="{{system.rechargeRate}}" min="0" />
    </div>

    {{!-- Damage --}}
    <div class="forja-form-row">
      <div class="forja-form-group forja-form-group--half">
        <label>{{localize "FORJA.DamageValue"}}</label>
        <input type="number" name="system.damageValue" value="{{system.damageValue}}" />
      </div>
      <div class="forja-form-group forja-form-group--half">
        <label>{{localize "FORJA.DamageType.label"}}</label>
        <select name="system.damageType">
          <option value="">--</option>
          {{#each cfg.damageTypes as |label key|}}
            <option value="{{key}}" {{#if (eq key ../system.damageType)}}selected{{/if}}>
              {{localize label}}
            </option>
          {{/each}}
        </select>
      </div>
    </div>

    {{!-- Protection --}}
    <div class="forja-form-group">
      <label>{{localize "FORJA.Protection"}}</label>
      <input type="number" name="system.protection" value="{{system.protection}}" />
    </div>

    {{!-- Base Weapon --}}
    <div class="forja-form-group">
      <label>{{localize "FORJA.BaseWeapon"}}</label>
      <input type="text" name="system.baseWeapon" value="{{system.baseWeapon}}" />
    </div>

    {{!-- Skill Bonuses --}}
    <div class="forja-form-group">
      <div class="forja-array-header">
        <label>{{localize "FORJA.SkillBonus"}}</label>
        <button type="button" class="forja-array-add" data-action="addSkillBonus" title="{{localize 'FORJA.Add'}}">+</button>
      </div>
      {{#each system.skillBonus as |entry i|}}
        <div class="forja-array-row" data-index="{{i}}">
          <input type="text" name="system.skillBonus.{{i}}.skillId" value="{{entry.skillId}}" placeholder="{{localize 'FORJA.SkillId'}}" class="forja-array-row__id" />
          <input type="number" name="system.skillBonus.{{i}}.bonus" value="{{entry.bonus}}" class="forja-array-row__num" />
          <button type="button" class="forja-array-remove" data-action="removeSkillBonus" data-index="{{i}}" title="{{localize 'FORJA.Remove'}}">&times;</button>
        </div>
      {{/each}}
    </div>

    {{!-- States Applied --}}
    <div class="forja-form-group">
      <div class="forja-array-header">
        <label>{{localize "FORJA.StatesApplied"}}</label>
        <button type="button" class="forja-array-add" data-action="addStateApplied" title="{{localize 'FORJA.Add'}}">+</button>
      </div>
      {{#each system.statesApplied as |entry i|}}
        <div class="forja-array-row" data-index="{{i}}">
          <input type="text" name="system.statesApplied.{{i}}.stateId" value="{{entry.stateId}}" placeholder="{{localize 'FORJA.StateId'}}" class="forja-array-row__id" />
          <input type="number" name="system.statesApplied.{{i}}.value" value="{{entry.value}}" class="forja-array-row__num" />
          <button type="button" class="forja-array-remove" data-action="removeStateApplied" data-index="{{i}}" title="{{localize 'FORJA.Remove'}}">&times;</button>
        </div>
      {{/each}}
    </div>

    {{!-- Traits Granted --}}
    <div class="forja-form-group">
      <div class="forja-array-header">
        <label>{{localize "FORJA.TraitsGranted"}}</label>
        <button type="button" class="forja-array-add" data-action="addTraitGranted" title="{{localize 'FORJA.Add'}}">+</button>
      </div>
      {{#each system.traitsGranted as |traitId i|}}
        <div class="forja-array-row" data-index="{{i}}">
          <input type="text" name="system.traitsGranted.{{i}}" value="{{traitId}}" placeholder="{{localize 'FORJA.TraitId'}}" class="forja-array-row__full" />
          <button type="button" class="forja-array-remove" data-action="removeTraitGranted" data-index="{{i}}" title="{{localize 'FORJA.Remove'}}">&times;</button>
        </div>
      {{/each}}
    </div>

    {{!-- Notes --}}
    <div class="forja-form-group">
      <label>{{localize "FORJA.Notes"}}</label>
      <div class="forja-item-sheet__notes">
        {{{enrichedDescription}}}
      </div>
      <textarea name="system.notes" rows="4">{{system.notes}}</textarea>
    </div>
  </div>
</form>
