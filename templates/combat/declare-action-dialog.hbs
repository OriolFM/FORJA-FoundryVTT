<form class="forja-declare-dialog">

  {{!-- Combatant info header --}}
  <div class="forja-declare-dialog__header">
    <img src="{{img}}" class="forja-declare-dialog__portrait" alt="{{name}}"/>
    <div class="forja-declare-dialog__header-text">
      <strong>{{name}}</strong>
      <span>{{localize "FORJA.Derived.Latency"}}: <b>{{baseLatency}}</b></span>
      {{#if currentPosition}}
      <span>{{localize "FORJA.Combat.CurrentPosition"}}: <b>{{currentPosition}}</b></span>
      {{/if}}
    </div>
  </div>

  {{!-- Action type --}}
  <div class="forja-declare-dialog__row">
    <label for="declare-action">{{localize "FORJA.Combat.ActionType"}}</label>
    <select id="declare-action" name="action">
      <option value="simple">{{localize "FORJA.Combat.ActionAttack"}}</option>
      <option value="defensive">{{localize "FORJA.Combat.ActionDefend"}}</option>
      <option value="movement">{{localize "FORJA.Combat.ActionMove"}}</option>
      <option value="special_movement">{{localize "FORJA.Combat.ActionSpecialMove"}}</option>
      <option value="concentrate">{{localize "FORJA.Combat.ActionConcentrate"}}</option>
      <option value="other">{{localize "FORJA.Combat.ActionOther"}}</option>
    </select>
  </div>

  {{!-- Defense sub-options (shown only for "defensive") --}}
  <div id="forja-defense-opts" class="forja-declare-dialog__row" style="display:none">
    <label for="declare-defense-type">{{localize "FORJA.Combat.DefenseType"}}</label>
    <select id="declare-defense-type" name="defenseType">
      <option value="dodge">{{localize "FORJA.Combat.DefenseDodge"}}</option>
      <option value="parry">{{localize "FORJA.Combat.DefenseParry"}}</option>
      <option value="block">{{localize "FORJA.Combat.DefenseBlock"}}</option>
      <option value="defend_other">{{localize "FORJA.Combat.DefenseOther"}}</option>
    </select>
  </div>

  {{!-- Weapon selector (only if actor has weapons) --}}
  {{#if weapons.length}}
  <div id="forja-weapon-opts" class="forja-declare-dialog__row">
    <label for="declare-weapon">{{localize "FORJA.Combat.Weapon"}}</label>
    <select id="declare-weapon" name="weaponId">
      <option value="">{{localize "FORJA.Combat.NoWeapon"}}</option>
      {{#each weapons}}
      <option value="{{this.id}}">{{this.name}} ({{signed this.latencyMod}})</option>
      {{/each}}
    </select>
  </div>
  {{/if}}

  {{!-- Target selector --}}
  {{#if targets.length}}
  <div id="forja-target-opts" class="forja-declare-dialog__row">
    <label for="declare-target">{{localize "FORJA.Combat.Target"}}</label>
    <select id="declare-target" name="targetId">
      <option value="">— {{localize "FORJA.Combat.NoTarget"}} —</option>
      {{#each targets}}
      <option value="{{this.id}}">{{this.name}}</option>
      {{/each}}
    </select>
  </div>
  <div class="forja-target-hint" style="display:none">
    <i class="fas fa-crosshairs"></i> {{localize "FORJA.Combat.SelectTargetHint"}}
  </div>
  {{/if}}

  {{!-- Movement options --}}
  <div class="forja-declare-dialog__row">
    <label>{{localize "FORJA.Combat.Movement"}}</label>
    <div class="forja-declare-dialog__move-options">
      <label>
        <input type="radio" name="moveType" value="none" checked/>
        {{localize "FORJA.Combat.NoMovement"}}
      </label>
      <label>
        <input type="radio" name="moveType" value="walk"/>
        <i class="fas fa-walking"></i> {{localize "FORJA.Combat.Walk"}} (max {{walkHexes}} hex)
      </label>
      <label>
        <input type="radio" name="moveType" value="run"/>
        <i class="fas fa-running"></i> {{localize "FORJA.Combat.Run"}} (max {{runHexes}} hex)
      </label>
      <div id="forja-hex-counter-row" class="forja-declare-dialog__hex-counter" style="display:none">
        <label for="declare-hex-count">{{localize "FORJA.Combat.HexCount"}}</label>
        <input type="number" id="declare-hex-count" name="hexCount"
               min="1" max="{{walkHexes}}" value="1"
               class="forja-declare-dialog__hex-input"
               data-walk="{{walkHexes}}" data-run="{{runHexes}}"/>
        <span id="forja-hex-max" class="forja-declare-dialog__hex-max">/ {{walkHexes}}</span>
      </div>
    </div>
  </div>

  {{!-- Final position preview --}}
  <div class="forja-declare-dialog__row forja-declare-dialog__position-preview">
    <label>{{localize "FORJA.Combat.FinalPosition"}}</label>
    <span id="declare-position-value" class="forja-declare-dialog__position-number">{{baseLatency}}</span>
  </div>

  {{!-- Free description --}}
  <div class="forja-declare-dialog__row">
    <label for="declare-desc">{{localize "FORJA.Combat.ActionDescription"}}</label>
    <input type="text" id="declare-desc" name="description" placeholder="..."/>
  </div>

</form>
