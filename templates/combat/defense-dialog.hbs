<form class="forja-defense-dialog">

  {{!-- Attacker info --}}
  <div class="forja-defense-dialog__combatants">
    <div class="forja-defense-dialog__fighter">
      <img src="{{attackerImg}}" class="forja-defense-dialog__portrait" alt="{{attackerName}}"/>
      <span class="forja-defense-dialog__fighter-name">{{attackerName}}</span>
      <span class="forja-defense-dialog__fighter-label">{{localize "FORJA.Combat.Attacker"}}</span>
    </div>
    <div class="forja-defense-dialog__vs">⚔</div>
    <div class="forja-defense-dialog__fighter">
      <img src="{{defenderImg}}" class="forja-defense-dialog__portrait" alt="{{defenderName}}"/>
      <span class="forja-defense-dialog__fighter-name">{{defenderName}}</span>
      <span class="forja-defense-dialog__fighter-label">{{localize "FORJA.Combat.Defender"}}</span>
    </div>
  </div>

  {{!-- Basic defense info --}}
  <div class="forja-defense-dialog__basic-info">
    <i class="fas fa-shield-alt"></i>
    {{localize "FORJA.Combat.BasicDefense" dice=defenseValue}}
  </div>

  {{!-- Active defense options (only if target can react) --}}
  {{#if canReact}}
  <div class="forja-defense-dialog__row">
    <label class="forja-defense-dialog__reaction-label">
      <input type="checkbox" id="forja-use-reaction" name="useReaction"/>
      <i class="fas fa-shield-halved"></i> {{localize "FORJA.Combat.SpendReaction"}}
      <span class="forja-defense-dialog__reaction-count">({{reactionsLeft}}/{{maxReactions}})</span>
    </label>
  </div>

  <div id="forja-active-defense-opts" class="forja-defense-dialog__maneuver-opts" style="display:none">
    <label class="forja-defense-dialog__maneuver-label">
      <input type="radio" name="defenseType" value="dodge" checked/>
      <i class="fas fa-person-running"></i>
      {{localize "FORJA.Combat.DefenseDodge"}}
      <span class="forja-defense-dialog__attr-hint">(AGI {{agiValue}}d)</span>
    </label>
    <label class="forja-defense-dialog__maneuver-label">
      <input type="radio" name="defenseType" value="parry"/>
      <i class="fas fa-hand-fist"></i>
      {{localize "FORJA.Combat.DefenseParry"}}
      <span class="forja-defense-dialog__attr-hint">(DES {{desValue}} + Armes CaC)</span>
    </label>
    <label class="forja-defense-dialog__maneuver-label">
      <input type="radio" name="defenseType" value="block"/>
      <i class="fas fa-shield"></i>
      {{localize "FORJA.Combat.DefenseBlock"}}
      <span class="forja-defense-dialog__attr-hint">(Def. est. + DR: +{{blockDRLabel}})</span>
    </label>
  </div>
  {{/if}}

</form>
