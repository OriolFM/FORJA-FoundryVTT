{{!-- FORJA Latency-based Combat Tracker --}}

{{#if combat}}
{{!-- Phase indicator & controls --}}
<div class="forja-combat-header">
  <div class="forja-combat-phase">
    {{#ifeq combatPhase "idle"}}
      <i class="fas fa-hourglass-start"></i> {{localize "FORJA.Combat.PhaseIdle"}}
    {{/ifeq}}
    {{#ifeq combatPhase "declaration"}}
      <i class="fas fa-scroll"></i> {{localize "FORJA.Combat.PhaseDeclaration"}}
    {{/ifeq}}
    {{#ifeq combatPhase "ambush_declaration"}}
      <i class="fas fa-eye-slash"></i> {{localize "FORJA.Combat.PhaseAmbush"}}
    {{/ifeq}}
    {{#ifeq combatPhase "resolution"}}
      <i class="fas fa-crosshairs"></i> {{localize "FORJA.Combat.PhaseResolution"}}
    {{/ifeq}}
    {{#ifeq combatPhase "ambush_resolution"}}
      <i class="fas fa-crosshairs"></i> {{localize "FORJA.Combat.PhaseAmbush"}} — {{localize "FORJA.Combat.PhaseResolution"}}
    {{/ifeq}}
  </div>

  {{#if isAmbush}}
    <div class="forja-ambush-badge">
      <i class="fas fa-eye-slash"></i> {{localize "FORJA.Combat.AmbushActive"}}
    </div>
  {{/if}}

  {{!-- GM Controls --}}
  {{#if user.isGM}}
  <div class="forja-combat-controls">
    {{#ifeq combatPhase "idle"}}
      <button type="button" class="forja-combat-controls__btn" data-action="startCombatPhase">
        <i class="fas fa-play"></i> {{localize "FORJA.Combat.Start"}}
      </button>
    {{/ifeq}}
    {{#ifeq combatPhase "declaration"}}
      <button type="button" class="forja-combat-controls__btn" data-action="advanceToNext"
              {{#unless allDeclared}}disabled{{/unless}}>
        <i class="fas fa-forward"></i> {{localize "FORJA.Combat.Advance"}}
      </button>
    {{/ifeq}}
    {{#ifeq combatPhase "ambush_declaration"}}
      <button type="button" class="forja-combat-controls__btn" data-action="advanceToNext"
              {{#unless allDeclared}}disabled{{/unless}}>
        <i class="fas fa-forward"></i> {{localize "FORJA.Combat.Advance"}}
      </button>
    {{/ifeq}}
    {{#ifeq combatPhase "resolution"}}
      <button type="button" class="forja-combat-controls__btn" data-action="finishResolution">
        <i class="fas fa-check-double"></i> {{localize "FORJA.Combat.FinishResolution"}}
      </button>
    {{/ifeq}}
    {{#ifeq combatPhase "ambush_resolution"}}
      <button type="button" class="forja-combat-controls__btn" data-action="finishResolution">
        <i class="fas fa-check-double"></i> {{localize "FORJA.Combat.FinishResolution"}}
      </button>
    {{/ifeq}}
  </div>
  {{/if}}

  {{!-- Pending damage summary --}}
  {{#if hasPendingDamage}}
  <div class="forja-pending-damage">
    <span class="forja-pending-damage__label">
      <i class="fas fa-tint"></i> {{localize "FORJA.Combat.PendingDamage"}}:
    </span>
    {{#each pendingDamage}}
      <span class="forja-pending-damage__entry">{{this.targetName}}: {{this.amount}}</span>
    {{/each}}
  </div>
  {{/if}}
</div>
{{/if}}

{{!-- Combatant list --}}
<ol id="combat-tracker" class="directory-list forja-combat-tracker">
  {{#each turns}}
  <li class="combatant {{side}} {{#if active}}active{{/if}} {{#if isResolving}}forja-resolving{{/if}} {{#if isDeclaring}}forja-declaring{{/if}} {{#if defeated}}defeated{{/if}}"
      data-combatant-id="{{id}}"
      data-tooltip="{{localize 'FORJA.Derived.Latency'}}: {{latency}} | {{localize 'FORJA.Derived.Defense'}}: {{defense}}">

    {{!-- Position number --}}
    <div class="forja-combat-position {{#if isResolving}}forja-combat-position--resolving{{/if}}">
      {{#if declaredAction}}
        {{position}}
      {{else}}
        —
      {{/if}}
    </div>

    {{!-- Combatant info --}}
    <div class="combatant-info">
      <img class="token-image" src="{{img}}" alt="{{name}}" />
      <div class="combatant-details">
        <span class="combatant-name">{{name}}</span>
        <span class="combatant-initiative" title="{{localize 'FORJA.Derived.Latency'}} base">
          {{localize "FORJA.Derived.Latency"}}: {{latency}}
        </span>
      </div>
    </div>

    {{!-- Health bars --}}
    <div class="combatant-health">
      {{#ifgt woundsPercent 0}}
      <div class="health-bar wounds-bar" title="{{localize 'FORJA.Health.Wounds'}}: {{forjaLocalize 'FORJA.WoundLevel' woundLevel}}">
        <div class="bar-fill" style="width: {{woundsPercent}}%"></div>
      </div>
      {{/ifgt}}
      {{#ifgt fatiguePercent 0}}
      <div class="health-bar fatigue-bar" title="{{localize 'FORJA.Health.Fatigue'}}: {{forjaLocalize 'FORJA.FatigueLevel' fatigueLevel}}">
        <div class="bar-fill" style="width: {{fatiguePercent}}%"></div>
      </div>
      {{/ifgt}}
    </div>

    {{!-- Declared action indicator --}}
    {{#if declaredAction}}
    <div class="declared-action" title="{{declaredAction.description}}">
      <i class="fas {{declaredAction.icon}}"></i>
    </div>
    {{/if}}

    {{!-- Reaction counters --}}
    <div class="forja-reactions" title="{{localize 'FORJA.Combat.Reactions'}}">
      {{#times maxReactions}}
        <i class="fas fa-shield-alt {{#ifgt ../reactionsAvailable this}}forja-reactions--available{{else}}forja-reactions--used{{/ifgt}}"></i>
      {{/times}}
      {{#if canReact}}
        <button type="button" class="forja-reactions__use-btn" data-action="useReaction" data-combatant-id="{{id}}"
                title="{{localize 'FORJA.Combat.UseReaction'}}">
          <i class="fas fa-shield-alt"></i>
        </button>
      {{/if}}
    </div>

    {{!-- Declaration panel --}}
    {{#if canDeclare}}
    <div class="forja-declare-panel">
      <select class="forja-declare-panel__action" data-combatant-id="{{id}}">
        <option value="simple">{{localize "FORJA.Combat.ActionAttack"}}</option>
        <option value="defensive">{{localize "FORJA.Combat.ActionDefend"}}</option>
        <option value="movement">{{localize "FORJA.Combat.ActionMove"}}</option>
        <option value="special_movement">{{localize "FORJA.Combat.ActionSpecialMove"}}</option>
        <option value="concentrate">{{localize "FORJA.Combat.ActionConcentrate"}}</option>
        <option value="other">{{localize "FORJA.Combat.ActionOther"}}</option>
      </select>
      {{#if weapons.length}}
      <select class="forja-declare-panel__weapon" data-combatant-id="{{id}}">
        <option value="">{{localize "FORJA.Combat.NoWeapon"}}</option>
        {{#each weapons}}
          <option value="{{this.id}}">{{this.name}} ({{signed this.system.latencyMod}})</option>
        {{/each}}
      </select>
      {{/if}}
      <div class="forja-declare-panel__latency">
        <i class="fas fa-clock"></i>
        <span class="forja-declare-panel__latency-value">{{latency}}</span>
      </div>
      <input type="text" class="forja-declare-panel__desc" placeholder="{{localize 'FORJA.Combat.ActionDescription'}}" />
      <button type="button" class="forja-declare-panel__btn" data-action="declareAction" data-combatant-id="{{id}}">
        <i class="fas fa-check"></i> {{localize "FORJA.Combat.Declare"}}
      </button>
    </div>
    {{/if}}

    {{!-- Controls (GM) --}}
    {{#if ../user.isGM}}
    <div class="combatant-controls">
      <a class="combatant-control" data-action="toggleDefeated" title="{{localize 'FORJA.Combat.defeated'}}">
        <i class="fas fa-skull"></i>
      </a>
    </div>
    {{/if}}
  </li>
  {{/each}}
</ol>
